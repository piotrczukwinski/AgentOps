{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "confidence", "summary", "blocking_issues", "repair_prompt"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["ACCEPT", "REQUEST_CHANGES", "BLOCK"]
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "summary": {"type": "string"},
    "blocking_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "issue", "severity", "suggested_fix"],
        "properties": {
          "file": {"type": "string"},
          "issue": {"type": "string"},
          "severity": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
          "suggested_fix": {"type": "string"}
        }
      }
    },
    "repair_prompt": {"type": "string"}
  }
}
